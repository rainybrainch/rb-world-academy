  "lessons": [
    {
      "id": "ch-001",
      "level": 1,
      "title": "基本表現 - 挨拶と自己紹介",
      "titleCh": "基本表达 - 问候和自我介绍",
      "objectives": [
        "基本的な中国語の挨拶を習得する",
        "簡単な自己紹介ができる",
        "人称代名詞を理解する"
      ],
      "content": {
        "introduction": "中国語を学ぶ第一歩。基本的な挨拶と自己紹介。",
        "sections": [
          {
            "title": "基本挨拶",
            "phrases": [
              {
                "chinese": "你好",
                "romaji": "Nǐ hǎo",
                "japanese": "こんにちは",
                "usage": "標準的な挨拶",
                "tone": "3-3"
              },
              {
                "chinese": "早上好",
                "romaji": "Zǎo shang hǎo",
                "japanese": "おはよう",
                "usage": "朝の挨拶",
                "tone": "3-1-3"
              },
              {
                "chinese": "晚上好",
                "romaji": "Wǎn shang hǎo",
                "japanese": "こんばんは",
                "usage": "夜の挨拶",
                "tone": "3-1-3"
              },
              {
                "chinese": "再见",
                "romaji": "Zài jiàn",
                "japanese": "さようなら",
                "usage": "別れの挨拶",
                "tone": "4-4"
              }
            ]
          },
          {
            "title": "自己紹介",
            "phrases": [
              {
                "chinese": "我叫...",
                "romaji": "Wǒ jiào...",
                "japanese": "私の名前は...",
                "usage": "名前を言う",
                "tone": "3-4"
              },
              {
                "chinese": "很高兴认识你",
                "romaji": "Hěn gāo xìng rènshi nǐ",
                "japanese": "お会いできて嬉しい",
                "usage": "初対面の挨拶",
                "tone": "3-1-4-4-3"
              },
              {
                "chinese": "你叫什么名字？",
                "romaji": "Nǐ jiào shénme míngzi?",
                "japanese": "お名前は？",
                "usage": "相手の名前を尋ねる",
                "tone": "3-4-3-5-4"
              }
            ]
          }
        ]
      },
      "practiceQuestions": [
        {
          "id": "ch-001-q1",
          "type": "fill-blank",
          "question": "朝の挨拶は？",
          "hint": "早+朝",
          "answer": "早上好",
          "difficulty": "easy"
        },
        {
          "id": "ch-001-q2",
          "type": "fill-blank",
          "question": "こんばんはは？",
          "hint": "晩+上",
          "answer": "晚上好",
          "difficulty": "easy"
        },
        {
          "id": "ch-001-q3",
          "type": "fill-blank",
          "question": "初めましては？",
          "hint": "初次",
          "answer": "初次见面",
          "difficulty": "medium"
        },
        {
          "id": "ch-001-q4",
          "type": "multiple-choice",
          "question": "目上の人への敬語は？",
          "options": [
            "你好",
            "您好",
            "嗨"
          ],
          "answer": "您好",
          "difficulty": "medium"
        }
      ],
      "culturalNotes": "中国の挨拶は握手より軽くお辞儀をする傾向。敬語が非常に重要で、関係性を大切にする文化。初対面では敬語を使用するのが基本。",
      "learningTips": [
        "声調が重要：中国語は4つの声調があり、同じ『ma』でも声調により意味が大きく異なる",
        "敬語の文脈：『你好』は比較的カジュアル。目上の人には『您好』が丁寧",
        "毎日練習：これらの表現は毎日使うので、何度も声に出して練習することが効果的"
      ],
      "challengeProblems": [
        {
          "text": "朝・昼・夜それぞれで、目上の人と友人に異なる敬語レベルで挨拶する文を作る",
          "difficulty": "high",
          "expectedTime": "10分"
        },
        {
          "text": "自分の名前・出身地・職業を組み合わせて、30秒の自己紹介を中国語で作成する",
          "difficulty": "high",
          "expectedTime": "15分"
        }
      ],
      "resources": [],
      "estimatedDuration": "10分",
      "cefr": "A1"
    },
