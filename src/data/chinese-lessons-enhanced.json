      "id": "ch-003",
      "level": 1,
      "title": "よく使う動詞",
      "titleCh": "常用动词",
      "objectives": [
        "基本動詞を習得する",
        "簡単な文を組み立てられる",
        "動詞の基本用法を理解する"
      ],
      "content": {
        "introduction": "日常会話に必須の動詞。これで表現の幅が大きく広がります。",
        "sections": [
          {
            "title": "基本動詞（食べる・飲む・行く・来る・見る）",
            "phrases": [
              {
                "chinese": "吃",
                "romaji": "Chī",
                "japanese": "食べる",
                "usage": "食事",
                "example": "我吃米饭。（ご飯を食べます。）"
              },
              {
                "chinese": "喝",
                "romaji": "Hē",
                "japanese": "飲む",
                "usage": "飲料",
                "example": "我喝茶。（お茶を飲みます。）"
              },
              {
                "chinese": "去",
                "romaji": "Qù",
                "japanese": "行く",
                "usage": "移動・目的地へ",
                "example": "我去北京。（北京に行きます。）"
              },
              {
                "chinese": "来",
                "romaji": "Lái",
                "japanese": "来る",
                "usage": "到着・接近",
                "example": "他来了。（彼が来ました。）"
              },
              {
                "chinese": "看",
                "romaji": "Kàn",
                "japanese": "見る",
                "usage": "視覚・観察",
                "example": "我看书。（本を読みます。）"
              }
            ]
          }
        ]
      },
      "practiceQuestions": [
        {
          "id": "ch-003-q1",
          "type": "fill-blank",
